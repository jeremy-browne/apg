---
import "../../styles/search.css";
import PagefindSearch from "astro-pagefind/components/Search";
import { Icon } from "astro-icon/components";
---

<dialog id="search-modal" aria-label="Search">
    <div class="flex flex-col">
        <div
            class="flex items-center justify-between border-b border-neutral-200 px-4 pt-4 pb-3 dark:border-neutral-700"
        >
            <span class="text-sm text-neutral-500 dark:text-neutral-400">
                Press <kbd
                    class="rounded bg-neutral-100 px-1.5 py-0.5 font-mono text-xs dark:bg-neutral-700"
                    >Esc</kbd
                > to close
            </span>
            <button
                id="close-search"
                type="button"
                class="rounded-md p-1 text-neutral-500 transition-colors hover:text-neutral-900 dark:hover:text-neutral-100"
                aria-label="Close search"
            >
                <Icon name="lucide:x" class="size-5" />
            </button>
        </div>
        <div class="overflow-y-auto px-4 py-4">
            <PagefindSearch
                id="search"
                className="pagefind-ui"
                uiOptions={{ showSubResults: true }}
            />
        </div>
    </div>
</dialog>

<style>
    dialog {
        position: fixed;
        top: 5rem;
        left: 50%;
        transform: translateX(-50%);
        width: min(calc(100vw - 2rem), 42rem);
        max-height: calc(100vh - 7rem);
        border: none;
        border-radius: 0.75rem;
        padding: 0;
        overflow: hidden;
        box-shadow:
            0 25px 50px -12px rgba(0, 0, 0, 0.25),
            0 0 0 1px rgba(0, 0, 0, 0.05);
        background-color: white;
    }

    :global(.dark) dialog {
        background-color: #171717;
        box-shadow:
            0 25px 50px -12px rgba(0, 0, 0, 0.6),
            0 0 0 1px rgba(255, 255, 255, 0.08);
    }

    dialog::backdrop {
        background: rgba(0, 0, 0, 0.5);
        backdrop-filter: blur(2px);
    }

    dialog[open] {
        animation: modal-in 180ms ease-out;
    }

    @keyframes modal-in {
        from {
            opacity: 0;
            transform: translateX(-50%) translateY(-0.375rem);
        }
        to {
            opacity: 1;
            transform: translateX(-50%) translateY(0);
        }
    }
</style>

<script>
    const modal = document.getElementById("search-modal") as HTMLDialogElement;
    const closeBtn = document.getElementById("close-search");

    const openModal = () => {
        modal.showModal();
        document.body.style.overflow = "hidden";
        requestAnimationFrame(() => {
            modal
                .querySelector<HTMLInputElement>(".pagefind-ui__search-input")
                ?.focus();
        });
    };

    const closeModal = () => modal.close();

    // Restore scroll when dialog closes (covers Escape key too)
    modal.addEventListener("close", () => {
        document.body.style.overflow = "";
    });

    // Close on backdrop click (fires on <dialog> when clicking outside content)
    modal.addEventListener("click", (e) => {
        if (e.target === modal) closeModal();
    });

    closeBtn?.addEventListener("click", closeModal);

    // Triggered by the header search button
    document.addEventListener("open-search", openModal);

    // Global "/" shortcut
    document.addEventListener("keydown", (e: KeyboardEvent) => {
        if (e.key !== "/") return;
        const target = e.target as HTMLElement;
        if (
            target.tagName === "INPUT" ||
            target.tagName === "TEXTAREA" ||
            target.isContentEditable
        )
            return;
        e.preventDefault();
        openModal();
    });
</script>
