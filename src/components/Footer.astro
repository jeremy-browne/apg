---
const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-inner">
    <p class="footer-brand">Aussie Pilot Guide</p>
    <p class="footer-tagline">Documenting the journey through Australian pilot training.</p>
    <p class="footer-copy">© {currentYear} Aussie Pilot Guide. All rights reserved.</p>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--navy);
    color: rgba(255, 255, 255, 0.65);
    padding: 2.5rem 1.5rem;
    margin-top: auto;
  }

  .footer-inner {
    max-width: 1100px;
    margin: 0 auto;
    text-align: center;
  }

  .footer-brand {
    color: white;
    font-weight: 700;
    font-size: 1.05rem;
    margin-bottom: 0.25rem;
  }

  .footer-tagline {
    font-size: 0.875rem;
    margin-bottom: 1rem;
  }

  .footer-copy {
    font-size: 0.775rem;
    opacity: 0.55;
    margin-bottom: 0;
  }
</style>
